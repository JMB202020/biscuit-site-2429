---
import '../styles/site.css';
const nav = [
  { label: 'Home',        href: '/2429' },
  { label: 'Kennels',     href: '/2429/kennels' },
  { label: 'Cattery',     href: '/2429/cattery' },
  { label: 'Pets at Home',href: '/2429/pet-sitting' },
  { label: 'Livery Yard', href: '/2429/livery' },
  { label: 'Rehoming',    href: '/2429/rehoming' },
  { label: 'Prices',      href: '/2429/prices' },
  { label: 'Gallery',     href: '/2429/gallery' },
  { label: 'Contact',     href: '/2429/contact' },
];
const img = (f: string) => `/2429/images/${f}`;
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Frequently Asked Questions | Reed House Kennels, Warrington</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="preload" href="/2429/fonts/nunito-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/2429/fonts/inter-latin.woff2" as="font" type="font/woff2" crossorigin />
  </head>
  <body class="bg-brand-bg">

    <div class="bg-brand-primary text-white py-2.5 px-4 text-center text-sm sticky top-0 z-50">
      <div class="max-w-5xl mx-auto flex flex-col sm:flex-row items-center justify-center gap-2 sm:gap-4">
        <span>Preview redesign for <strong>Reed House Kennels</strong> by <strong>Biscuit Web</strong></span>
        <a href="https://biscuitweb.co.uk/activate?id=2429&name=Reed%20House%20Kennels" class="inline-flex items-center px-4 py-1 bg-brand-accent text-brand-primary font-bold text-xs rounded-full hover:opacity-80 transition-opacity shrink-0">Like it? Activate for &pound;50</a>
      </div>
    </div>

    <header class="bg-white border-b border-border sticky top-10 z-40">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 py-3 flex items-center justify-between">
        <a href="/2429" class="font-display font-extrabold text-lg text-brand-primary leading-tight">Reed House<span class="text-brand-accent"> Kennels</span></a>
        <button class="lg:hidden p-2 text-ink-soft" onclick="document.getElementById('mobile-nav-faq').classList.toggle('hidden')" aria-label="Menu">
          <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
        </button>
        <nav class="hidden lg:flex items-center gap-5">
          {nav.map(n => (
            <a href={n.href} class="text-sm font-semibold text-ink-soft hover:text-brand-primary transition-colors">{n.label}</a>
          ))}
          <a href="tel:01619415699" class="inline-flex items-center px-4 py-2 bg-brand-primary text-white font-display font-bold text-sm rounded-lg hover:opacity-90 transition-opacity">0161 941 5699</a>
        </nav>
      </div>
      <nav id="mobile-nav-faq" class="hidden lg:hidden px-4 pb-4 space-y-2 bg-white border-t border-border">
        {nav.map(n => (
          <a href={n.href} class="text-ink-soft block text-sm font-semibold hover:text-brand-primary py-1">{n.label}</a>
        ))}
        <a href="tel:01619415699" class="block px-4 py-2.5 bg-brand-primary text-white font-display font-bold text-sm rounded-lg text-center">0161 941 5699</a>
      </nav>
    </header>

    <!-- Page header -->
    <section class="bg-brand-primary py-16 sm:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6">
        <h1 class="font-display font-extrabold text-3xl sm:text-5xl lg:text-6xl text-white">Frequently Asked Questions</h1>
        <p class="mt-4 text-white/80 text-lg max-w-xl">We hope you find your answer here. If not, call us on <a href="tel:01619415699" class="underline">0161 941 5699</a> and we'll be happy to help.</p>
      </div>
    </section>

    <!-- FAQs -->
    <section class="py-16 sm:py-20 bg-white">
      <div class="mx-auto max-w-4xl px-4 sm:px-6">
        <div class="space-y-6">

          <div class="bg-brand-bg rounded-2xl p-6 border border-border">
            <h2 class="font-display font-bold text-xl text-ink mb-3">What are your opening hours?</h2>
            <p class="text-ink-soft mb-3">We operate the same hours for all bank holidays throughout the year except Christmas Day, Boxing Day and New Year's Day when reception is closed. During Christmas we are still here looking after your pets but reception is closed.</p>
            <p class="text-ink-soft mb-3">We do have a half-hour window at 11am to 11.30am on Boxing Day only when we accept pets in to stay with us for the holiday season. Please call for details.</p>
            <div class="mt-4 bg-white rounded-xl border border-border overflow-hidden">
              <div class="flex justify-between p-4 border-b border-border">
                <span class="font-semibold text-ink">Monday to Friday (inc Bank Holidays)</span>
                <span class="text-ink-soft text-sm">9.00am to 11.00am &amp; 2.00pm to 6.00pm</span>
              </div>
              <div class="flex justify-between p-4 border-b border-border">
                <span class="font-semibold text-ink">Saturday</span>
                <span class="text-ink-soft text-sm">9.00am to 4.00pm</span>
              </div>
              <div class="flex justify-between p-4">
                <span class="font-semibold text-ink">Sundays</span>
                <span class="text-ink-soft text-sm">10.00am to 4.00pm</span>
              </div>
            </div>
          </div>

          <div class="bg-brand-bg rounded-2xl p-6 border border-border">
            <h2 class="font-display font-bold text-xl text-ink mb-3">Do you take in other animals apart from dogs?</h2>
            <p class="text-ink-soft">Yes, our staff are trained and experienced to handle all types of animals. Please contact us to discuss your requirements.</p>
          </div>

          <div class="bg-brand-bg rounded-2xl p-6 border border-border">
            <h2 class="font-display font-bold text-xl text-ink mb-3">Can I visit the kennels before booking?</h2>
            <p class="text-ink-soft mb-3">We actively encourage new customers to come and see our kennels and cattery. Visiting time is between 2pm and 4pm any day of the week. You can just call in. You do not need an appointment.</p>
            <p class="text-ink-soft mb-3">Although some people would like to call in the morning, we are very busy during that time with feeding, cleaning and our daily routines, as well as accepting morning arrivals. We are ready to chat after lunch when all the animals have settled down for a snooze.</p>
            <p class="text-ink-soft">For health and safety reasons we do not allow anyone under 16 in the kennels. Please call for more details on 0161 941 5999.</p>
          </div>

          <div class="bg-brand-bg rounded-2xl p-6 border border-border">
            <h2 class="font-display font-bold text-xl text-ink mb-3">What do I need to bring?</h2>
            <p class="text-ink-soft mb-3">Here is what you need and might like to bring:</p>
            <ul class="space-y-2">
              <li class="flex gap-3 text-ink-soft"><span class="text-brand-primary font-bold shrink-0">Must bring:</span>Vaccination records.</li>
              <li class="flex gap-3 text-ink-soft"><span class="text-brand-primary font-bold shrink-0">Nice to bring:</span>Bed and blanket, toys, food if on a special diet, any medication your pet may require.</li>
            </ul>
          </div>

          <div class="bg-brand-bg rounded-2xl p-6 border border-border">
            <h2 class="font-display font-bold text-xl text-ink mb-3">Do you walk the dogs, and if so how often?</h2>
            <p class="text-ink-soft">Yes we do. All dogs have a minimum of 2 walks per day, often more. They also receive lots of love, fuss, care and attention. Please feel free to arrange a visit so we can show you how we operate.</p>
          </div>

          <div class="bg-brand-bg rounded-2xl p-6 border border-border">
            <h2 class="font-display font-bold text-xl text-ink mb-3">What type of food do you supply?</h2>
            <p class="text-ink-soft">We have a variety of dried food, two of which are wheat and gluten-free. We also have a variety of tinned food including Winalot, Chappie and Butchers.</p>
          </div>

          <div class="bg-brand-bg rounded-2xl p-6 border border-border">
            <h2 class="font-display font-bold text-xl text-ink mb-3">How are your fees calculated?</h2>
            <p class="text-ink-soft">We charge a daily rate. This means that if your dog spends any part of a day with us then a fee is payable for that day. This is in line with the vast majority of kennels. Please see our <a href="/2429/terms" class="text-brand-primary underline">terms and conditions</a> for further information.</p>
          </div>

          <div class="bg-brand-bg rounded-2xl p-6 border border-border">
            <h2 class="font-display font-bold text-xl text-ink mb-3">Can you pick up our dog from home?</h2>
            <p class="text-ink-soft">Yes. You can call us to discuss your requirements, but please note that there may be a small extra charge for this service. We can also bring your dog back for you if required.</p>
          </div>

          <div class="bg-brand-bg rounded-2xl p-6 border border-border">
            <h2 class="font-display font-bold text-xl text-ink mb-3">Do you offer a bathing and grooming service?</h2>
            <p class="text-ink-soft">We only offer a bathing service for dogs. We no longer offer a full grooming service.</p>
          </div>

        </div>

        <div class="mt-10 text-center">
          <p class="text-ink-soft mb-4">Still got a question?</p>
          <a href="tel:01619415699" class="inline-flex items-center px-6 py-3 bg-brand-primary text-white font-display font-bold text-base rounded-xl hover:opacity-90 transition-all">Call us: 0161 941 5699</a>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="bg-ink text-white py-12">
      <div class="mx-auto max-w-7xl px-4 sm:px-6">
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8 mb-8">
          <div>
            <p class="font-display font-extrabold text-xl mb-2">Reed House Kennels</p>
            <p class="text-white/60 text-sm">Reed House Farm<br />Gorsey Lane, Warburton, Lymm<br />Cheshire WA13 9UB</p>
            <p class="text-white/60 text-sm mt-3"><a href="tel:01619415699" class="hover:text-white">0161 941 5699</a></p>
            <p class="text-white/60 text-sm"><a href="mailto:info@reedhousekennels.co.uk" class="hover:text-white">info@reedhousekennels.co.uk</a></p>
          </div>
          <div>
            <p class="font-display font-bold mb-3 text-white/80">Services</p>
            <ul class="space-y-1.5">
              <li><a href="/2429/kennels" class="text-white/60 text-sm hover:text-white">Kennels</a></li>
              <li><a href="/2429/cattery" class="text-white/60 text-sm hover:text-white">Cattery</a></li>
              <li><a href="/2429/pet-sitting" class="text-white/60 text-sm hover:text-white">Pets Stay at Home</a></li>
              <li><a href="/2429/livery" class="text-white/60 text-sm hover:text-white">Livery Yard</a></li>
              <li><a href="/2429/rehoming" class="text-white/60 text-sm hover:text-white">Rehoming</a></li>
            </ul>
          </div>
          <div>
            <p class="font-display font-bold mb-3 text-white/80">Information</p>
            <ul class="space-y-1.5">
              <li><a href="/2429/prices" class="text-white/60 text-sm hover:text-white">Prices</a></li>
              <li><a href="/2429/gallery" class="text-white/60 text-sm hover:text-white">Gallery</a></li>
              <li><a href="/2429/team" class="text-white/60 text-sm hover:text-white">Our Team</a></li>
              <li><a href="/2429/faq" class="text-white/60 text-sm hover:text-white">FAQ</a></li>
              <li><a href="/2429/testimonials" class="text-white/60 text-sm hover:text-white">Testimonials</a></li>
              <li><a href="/2429/contact" class="text-white/60 text-sm hover:text-white">Contact Us</a></li>
            </ul>
          </div>
          <div>
            <p class="font-display font-bold mb-3 text-white/80">More</p>
            <ul class="space-y-1.5">
              <li><a href="/2429/dogs-and-litters" class="text-white/60 text-sm hover:text-white">Our Dogs &amp; Litters</a></li>
              <li><a href="/2429/terms" class="text-white/60 text-sm hover:text-white">Terms &amp; Conditions</a></li>
            </ul>
          </div>
        </div>
        <div class="border-t border-white/10 pt-6 flex flex-col sm:flex-row items-center justify-between gap-3">
          <p class="text-white/40 text-xs">&copy; 2025 Reed House Kennels. All rights reserved.</p>
          <p class="text-white/30 text-xs">Preview redesign by <a href="https://biscuitweb.co.uk" class="hover:text-white/60">Biscuit Web</a></p>
        </div>
      </div>
    </footer>

  </body>
</html>
